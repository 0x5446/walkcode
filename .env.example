# Feishu App (https://open.feishu.cn/app)
FEISHU_APP_ID=cli_xxxx
FEISHU_APP_SECRET=xxxx

# Optional: OpenAPI domain
# Feishu: https://open.feishu.cn (default)
# Lark:    https://open.larksuite.com
# LARK_OPENAPI_DOMAIN=https://open.larksuite.com

# Your open_id (send any message to the bot, check server logs)
FEISHU_RECEIVE_ID=ou_xxxx

# Optional: open_id (default) or chat_id
# FEISHU_RECEIVE_ID_TYPE=open_id

# Optional: HTTP server port (default: 3001)
# PORT=3001

# Optional: persistent session state path
# default: ~/.walkcode/state.json for the main Claude instance,
#          ~/.walkcode/<instance>-state.json for other instances
# WALKCODE_STATE_PATH=~/.walkcode/state.json

# Optional: default working directory for remote-started sessions
# (default: ~/.walkcode/workspace)
# WALKCODE_CWD=~/projects

# Optional: agent type — claude (default) or codex
# WALKCODE_AGENT=claude

# Optional: instance name for multi-agent (separate PID/log/state per instance)
# WALKCODE_INSTANCE=codex

# --- Per-instance routing (advanced) ---
# Replace the default permission/approval flag.
#   e.g. fully autonomous Codex: --yolo
#   unset = adapter default (claude --permission-mode default,
#           codex --ask-for-approval untrusted)
# WALKCODE_PERMISSION_FLAG=--yolo
# Extra flags inserted after the agent command, e.g. route Claude through Vertex.
# NOTE: values are kept literal — use an ABSOLUTE path, ~ / $HOME are NOT expanded:
# WALKCODE_EXTRA_ARGS=--settings /Users/you/.walkcode/vertex.json

# --- Session health card ---
# Live status card per session thread. On by default; set 0 to disable.
# WALKCODE_HEALTH_CARD=0
# Optional: auto-summarize the thread title via Claude Haiku on Vertex.
# Codex sessions only (Claude uses its own AI title). Requires the optional
# `summary` extra (anthropic[vertex]); Codex degrades to the task's first line
# when unset/unavailable. Use absolute paths; keep the SA JSON out of any repo.
# WALKCODE_SUMMARY_VERTEX_PROJECT=your-gcp-project
# WALKCODE_SUMMARY_VERTEX_REGION=global
# WALKCODE_SUMMARY_SA_PATH=/Users/you/.walkcode/vertex-sa.json
# WALKCODE_SUMMARY_MODEL=claude-haiku-4-5
# WALKCODE_SUMMARY_TIMEOUT=8

# Optional: agent-specific env vars forwarded to remote-started sessions
# ANTHROPIC_API_KEY=sk-xxx          # for Claude Code
# OPENAI_API_KEY=sk-xxx             # for Codex CLI
