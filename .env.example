# Feishu App (https://open.feishu.cn/app)
FEISHU_APP_ID=cli_xxxx
FEISHU_APP_SECRET=xxxx

# Optional: OpenAPI domain
# Feishu: https://open.feishu.cn (default)
# Lark:    https://open.larksuite.com
# LARK_OPENAPI_DOMAIN=https://open.larksuite.com

# Your open_id (send any message to the bot, check server logs)
FEISHU_RECEIVE_ID=ou_xxxx

# Optional: persistent session state path (default: ~/.walkcode/state.json)
# WALKCODE_STATE_PATH=~/.walkcode/state.json

# Optional: default working directory for Feishu-initiated sessions (default: $HOME)
# WALKCODE_CWD=~/projects

# Optional: agent type — claude (default) or codex
# WALKCODE_AGENT=claude

# Optional: instance name for multi-agent (separate PID/log/state per instance)
# WALKCODE_INSTANCE=codex

# Optional: agent-specific env vars forwarded to remote-started sessions
# ANTHROPIC_API_KEY=sk-xxx          # for Claude Code
# OPENAI_API_KEY=sk-xxx             # for Codex CLI
